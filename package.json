{
  "name": "code-reviewer",
  "displayName": "Code Reviewer",
  "description": "AI-powered review of file structure, naming conventions, variables, and modularity",
  "version": "0.0.1",
  "publisher": "xirvo.co",
  "engines": { "vscode": "^1.74.0" },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "code-reviewer",
          "title": "Code Reviewer",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "code-reviewer": [
        {
          "type": "webview",
          "id": "codeReviewer.panel",
          "name": "Code Review"
        }
      ]
    },
    "configuration": {
      "title": "Code Reviewer",
      "properties": {
        "codeReviewer.provider": {
          "type": "string",
          "enum": ["claude", "openai", "gemini"],
          "enumDescriptions": [
            "Anthropic Claude",
            "OpenAI GPT",
            "Google Gemini"
          ],
          "default": "claude",
          "description": "Default LLM provider for workspace reviews.",
          "scope": "application"
        },
        "codeReviewer.claudeApiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "[Anthropic](https://console.anthropic.com/) API key. Stored locally in user settings.",
          "scope": "application"
        },
        "codeReviewer.openaiApiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "[OpenAI](https://platform.openai.com/api-keys) API key. Stored locally in user settings.",
          "scope": "application"
        },
        "codeReviewer.geminiApiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "[Google AI Studio](https://aistudio.google.com/apikey) Gemini API key. Stored locally in user settings.",
          "scope": "application"
        },
        "codeReviewer.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Deprecated — use `codeReviewer.claudeApiKey` instead.",
          "scope": "application",
          "deprecationMessage": "Use codeReviewer.claudeApiKey"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "npm run build -- --watch",
    "package": "npm run build && vsce package",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.0.0"
  }
}
